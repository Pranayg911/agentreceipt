{
  "name": "agentreceipt",
  "version": "0.1.0",
  "description": "Signed verification for AI-generated code work. AgentReceipt auto-detects Claude Code, Codex, and Cursor evidence, catches failed checks, skipped verification, and unsupported claims, then emits an ed25519-verifiable Trust Receipt.",
  "type": "module",
  "license": "MIT",
  "keywords": ["ai", "agents", "claude-code", "cursor", "coding-agent", "trust", "eval", "ed25519", "verifiable", "transcript"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "agentreceipt": "./dist/cli.js" },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.5"
  }
}
